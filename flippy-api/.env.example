# flippy-api — variables de entorno
# Copiar a .env y completar valores reales. Nunca commitear .env.

ENVIRONMENT=development

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Connection string a Postgres via Session Pooler (Project Settings -> Database -> Connection
# string -> Session pooler). NO usar "Direct connection": requiere IPv6 y falla en redes IPv4-only.
# Solo necesaria para migraciones (DDL); la app en runtime usa SUPABASE_URL + SERVICE_ROLE_KEY via API REST
SUPABASE_DB_URL=

# LLM — chat RAG (Google Gemini 2.0 Flash)
GOOGLE_API_KEY=

# LLM — analisis de imagenes (Anthropic Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=

# Embeddings (OpenAI text-embedding-3-small)
OPENAI_API_KEY=

# Mercado Pago
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# Auth — Supabase Auth (GoTrue). El registro/login/tokens los emite Supabase, no FastAPI.
# FastAPI valida los JWT contra el JWKS publico del proyecto (SUPABASE_URL/auth/v1/.well-known/jwks.json),
# no requiere ningun secreto propio.
# ADMIN_EMAILS: lista separada por comas de emails con rol administrador (acceso a /admin)
ADMIN_EMAILS=
